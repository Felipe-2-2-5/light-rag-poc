</node>
<node id="Retrieval Component">
  <data key="d0">Retrieval Component</data>
  <data key="d1">concept</data>
  <data key="d2">The Retrieval Component is an essential element of a RAG framework, responsible for fetching relevant documents or information from an external knowledge database.</data>
  <data key="d3">chunk-69aa0eae6d1f6ab69e22f063ae2a2e46</data>
  <data key="d4">unknown_source</data>
