<node id="Neighboring Nodes">
  <data key="d0">Neighboring Nodes</data>
  <data key="d1">concept</data>
  <data key="d2">Nodes gathered within local subgraphs of retrieved graph elements to enhance queries with higher-order relatedness.</data>
