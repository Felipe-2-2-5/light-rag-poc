  <data key="d6"></data>
</node>
<node id="Incorporating High-Order Relatedness">
  <data key="d0">Incorporating High-Order Relatedness</data>
  <data key="d1">method</data>
  <data key="d2">A process by LightRAG to enhance queries by gathering neighboring nodes within local subgraphs of retrieved graph elements.</data>
  <data key="d3">chunk-47f20c669a70fff5620e01924436985d</data>
  <data key="d4">unknown_source</data>
