  <data key="d4">unknown_source</data>
  <data key="d5">1768751036</data>
  <data key="d6"></data>
</node>
<node id="Low-Level-Only Retrieval">
  <data key="d0">Low-Level-Only Retrieval</data>
  <data key="d1">method</data>
  <data key="d2">A retrieval approach that emphasizes specific information, entities, and their immediate neighbors, struggling with complex queries requiring comprehensive insights.</data>
  <data key="d3">chunk-45c46ee88a9a2d60d923862ae51dbb45</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1768751036</data>
  <data key="d6"></data>
</node>
<node id="High-Order Retrieval">
  <data key="d0">High-Order Retrieval</data>
  <data key="d1">method</data>
  <data key="d2">A retrieval technique, the removal of which, as in the -High variant, can lead to significant performance decline.</data>
  <data key="d3">chunk-45c46ee88a9a2d60d923862ae51dbb45</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1768751036</data>
  <data key="d6"></data>
</node>
<node id="High-Level-Only Retrieval">
  <data key="d0">High-Level-Only Retrieval</data>
  <data key="d1">method</data>
  <data key="d2">A retrieval approach that prioritizes capturing a broader range of content by leveraging entity-wise relationships, offering an advantage in comprehensiveness but with reduced depth.</data>
  <data key="d3">chunk-45c46ee88a9a2d60d923862ae51dbb45</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1768751036</data>
  <data key="d6"></data>
</node>
<node id="Hybrid Mode">
  <data key="d0">Hybrid Mode</data>
  <data key="d1">method</data>
  <data key="d2">A retrieval approach, also known as the full version of LightRAG, that combines the strengths of both low-level and high-level retrieval methods.</data>
  <data key="d3">chunk-45c46ee88a9a2d60d923862ae51dbb45</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1768751036</data>
  <data key="d6"></data>
</node>
<node id="Semantic Graph">
  <data key="d0">Semantic Graph</data>
  <data key="d1">data</data>
  <data key="d2">A representation that excels in Retrieval-Augmented Generation (RAG) by enabling effective extraction of key information during the graph-based indexing process.</data>
  <data key="d3">chunk-45c46ee88a9a2d60d923862ae51dbb45</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1768751036</data>
  <data key="d6"></data>
