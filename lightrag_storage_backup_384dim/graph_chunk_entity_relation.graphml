<node id="Original Text">
  <data key="d0">Original Text</data>
  <data key="d1">content</data>
  <data key="d2">A source of information that, when used in retrieval, can contain irrelevant details that introduce noise.</data>
  <data key="d3">chunk-45c46ee88a9a2d60d923862ae51dbb45</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1768751036</data>
  <data key="d6"></data>
