  <data key="d1">method</data>
  <data key="d2">The method by which LightRAG fetches information, enhanced by graph structures and a dual-level system.</data>
  <data key="d3">chunk-0747de8554c174a10ea77615f403b7d8</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1768751034</data>
  <data key="d6"></data>
</node>
<node id="Dual-Level Retrieval System">
  <data key="d0">Dual-Level Retrieval System</data>
  <data key="d1">method</data>
  <data key="d2">An innovative framework employed by LightRAG that enhances comprehensive information retrieval from both low-level and high-level knowledge discovery.</data>
  <data key="d3">chunk-0747de8554c174a10ea77615f403b7d8</data>
  <data key="d4">unknown_source</data>
