  <data key="d1">data</data>
  <data key="d2">Nodes that have been retrieved, whose one-hop neighboring nodes (Nv) are gathered to enhance query relatedness.</data>
  <data key="d3">chunk-47f20c669a70fff5620e01924436985d</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1768751032</data>
