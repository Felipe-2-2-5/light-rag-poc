<node id="Four Evaluation Dimensions">
  <data key="d0">Four Evaluation Dimensions</data>
  <data key="d1">concept</data>
  <data key="d2">A set of criteria used for ranking RAG system answers, including Comprehensiveness, Diversity, Empowerment, and Overall.</data>
  <data key="d3">chunk-fef3e239f1910dc4633864fe3bf43b2f</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1768751026</data>
  <data key="d6"></data>
