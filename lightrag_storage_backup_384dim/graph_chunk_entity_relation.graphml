  <data key="d0">NaiveRAG -Origin</data>
  <data key="d1">method</data>
  <data key="d2">A variant of NaiveRAG where the use of original text is eliminated from the retrieval process.</data>
  <data key="d3">chunk-45c46ee88a9a2d60d923862ae51dbb45</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1768751036</data>
